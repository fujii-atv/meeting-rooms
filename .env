# =====================================================================
# 社内会議室予約アプリ — 環境変数
# このファイルをコピーして .env として保存し、各値を埋めてください
# .env はGitにコミットせず、本番ではVercel管理画面に登録します
# =====================================================================

# Google Cloud Console で発行した OAuth クライアント ID
# https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=122298742681-rl5uft1qknk6ict8mffgpa0jo3fstupf.apps.googleusercontent.com

# 会社のドメイン（このドメインのアカウントだけログインを許可する）
# 例: example.co.jp
VITE_COMPANY_DOMAIN=archetype.vc

# 各会議室のリソースカレンダーID（Google Workspace管理コンソールでリソースとして登録したメールアドレス）
# 不要な会議室は空欄にしておくと、アプリ画面に表示されません
VITE_ROOM_1_CAL_ID=c_1887d4l3s418egdlk9q2u3bq90fem@resource.calendar.google.com
VITE_ROOM_2_CAL_ID=c_1888n4i6rt7toij2md3ul9bmam4bi@resource.calendar.google.com
VITE_ROOM_3_CAL_ID=c_188ce7im7s11aj3ih7mla84dqgk1m@resource.calendar.google.com
